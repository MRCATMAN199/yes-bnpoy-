  <script src="/_sdk/7395a30b3453963f.editing_sdk.js" integrity="sha512-anMP2CGgmjTrBjYYA5HoQqgmlvkMVGOwa7Tbl+RkQuzxCegwznSoyZd4OdabUjysA29ZAREErXKS4mFM1f45bQ=="></script>
  <script>
    lucide.createIcons();

    // ---- Instrument definitions (accent colors + synth params live in JS, not config) ----
    const INSTRUMENTS = [
      { id: 'kick',    color: '#ff5a3c' },
      { id: 'snare',   color: '#ffb03c' },
      { id: 'hihat',   color: '#ffe14d' },
      { id: 'openhat', color: '#8bff4d' },
      { id: 'bass',    color: '#3cffd0' },
      { id: 'lead',    color: '#4d9bff' },
      { id: 'brass',   color: '#c77dff' },
    ];
    const STEPS = 16;

    const pattern = {};
    INSTRUMENTS.forEach(i => pattern[i.id] = new Array(STEPS).fill(false));

    // ---- Build beat-number header ----
    const beatHeader = document.getElementById('beat-header');
    for (let i = 0; i < STEPS; i++) {
      const n = document.createElement('div');
      n.className = 'beat-num' + (i % 4 === 0 && i !== 0 ? ' step-group' : '') + (i % 4 === 0 ? ' downbeat' : '');
      n.textContent = i + 1;
      beatHeader.appendChild(n);
    }

    // ---- Build step grid ----
    INSTRUMENTS.forEach(inst => {
      const container = document.querySelector('.steps[data-inst="' + inst.id + '"]');
      const row = container.closest('.rack-row');
      row.style.setProperty('--accent', inst.color);
      for (let i = 0; i < STEPS; i++) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'step' + (i % 4 === 0 && i !== 0 ? ' step-group' : '');
        btn.dataset.step = i;
        btn.setAttribute('aria-label', inst.id + ' step ' + (i + 1));
        btn.setAttribute('aria-pressed', 'false');
        btn.addEventListener('click', () => {
          const on = !pattern[inst.id][i];
          pattern[inst.id][i] = on;
          btn.classList.toggle('active', on);
          btn.setAttribute('aria-pressed', String(on));
        });
        container.appendChild(btn);
      }
    });

    // ================= Web Audio Engine =================
    let audioCtx = null;
    let master = null;
    let noiseBuf = null;
    let tempo = 120;
    let masterVol = 0.8;

    let isPlaying = false;
    let currentStep = 0;
    let nextNoteTime = 0;
    const LOOKAHEAD = 25;         // ms
    const SCHEDULE_AHEAD = 0.1;   // s
    let timerID = null;
    let notesInQueue = [];
    let lastDrawStep = -1;

    function initAudio() {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      master = audioCtx.createGain();
      master.gain.value = masterVol;
      master.connect(audioCtx.destination);
      // noise buffer for percussion
      const len = audioCtx.sampleRate * 0.5;
      noiseBuf = audioCtx.createBuffer(1, len, audioCtx.sampleRate);
      const data = noiseBuf.getChannelData(0);
      for (let i = 0; i < len; i++) data[i] = Math.random() * 2 - 1;
    }

    function playKick(t) {
      const o = audioCtx.createOscillator();
      const g = audioCtx.createGain();
      o.frequency.setValueAtTime(150, t);
      o.frequency.exponentialRampToValueAtTime(40, t + 0.16);
      g.gain.setValueAtTime(1, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.42);
      o.connect(g).connect(master);
      o.start(t); o.stop(t + 0.45);
    }

    function playSnare(t) {
      const src = audioCtx.createBufferSource(); src.buffer = noiseBuf;
      const hp = audioCtx.createBiquadFilter(); hp.type = 'highpass'; hp.frequency.value = 1200;
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.65, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.2);
      src.connect(hp).connect(g).connect(master);
      src.start(t); src.stop(t + 0.2);
      const o = audioCtx.createOscillator(); o.type = 'triangle'; o.frequency.value = 190;
      const g2 = audioCtx.createGain();
      g2.gain.setValueAtTime(0.5, t);
      g2.gain.exponentialRampToValueAtTime(0.001, t + 0.14);
      o.connect(g2).connect(master); o.start(t); o.stop(t + 0.14);
    }

    function playHat(t, dur, level) {
      const src = audioCtx.createBufferSource(); src.buffer = noiseBuf;
      const hp = audioCtx.createBiquadFilter(); hp.type = 'highpass'; hp.frequency.value = 7000;
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(level, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + dur);
      src.connect(hp).connect(g).connect(master);
      src.start(t); src.stop(t + dur);
    }

    function playSynth(t, opts) {
      const dur = opts.dur;
      const g = audioCtx.createGain();
      const filt = audioCtx.createBiquadFilter();
      filt.type = 'lowpass'; filt.frequency.value = opts.filter;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(opts.gain, t + opts.attack);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      filt.connect(g).connect(master);
      // one or two detuned oscillators
      const detunes = opts.detune ? [-opts.detune, opts.detune] : [0];
      detunes.forEach(d => {
        const o = audioCtx.createOscillator();
        o.type = opts.type; o.frequency.value = opts.freq; o.detune.value = d;
        o.connect(filt); o.start(t); o.stop(t + dur);
      });
    }

    function trigger(id, t) {
      switch (id) {
        case 'kick':    playKick(t); break;
        case 'snare':   playSnare(t); break;
        case 'hihat':   playHat(t, 0.05, 0.4); break;
        case 'openhat': playHat(t, 0.32, 0.32); break;
        case 'bass':    playSynth(t, { freq: 55,  type: 'sawtooth', dur: 0.26, filter: 420,  attack: 0.005, gain: 0.55 }); break;
        case 'lead':    playSynth(t, { freq: 440, type: 'square',   dur: 0.20, filter: 3200, attack: 0.005, gain: 0.28 }); break;
        case 'brass':   playSynth(t, { freq: 220, type: 'sawtooth', dur: 0.36, filter: 1600, attack: 0.05,  gain: 0.30, detune: 8 }); break;
      }
    }

    // ---- Scheduler ----
    function nextNote() {
      const secondsPerBeat = 60.0 / tempo;
      nextNoteTime += 0.25 * secondsPerBeat; // 16th note
      currentStep = (currentStep + 1) % STEPS;
    }

    function scheduleStep(step, time) {
      notesInQueue.push({ step, time });
      INSTRUMENTS.forEach(inst => {
        if (pattern[inst.id][step]) trigger(inst.id, time);
      });
    }

    function scheduler() {
      while (nextNoteTime < audioCtx.currentTime + SCHEDULE_AHEAD) {
        scheduleStep(currentStep, nextNoteTime);
        nextNote();
      }
      timerID = setTimeout(scheduler, LOOKAHEAD);
    }

    function highlightColumn(step) {
      document.querySelectorAll('.step.playing').forEach(e => e.classList.remove('playing'));
      if (step >= 0) {
        document.querySelectorAll('.step[data-step="' + step + '"]').forEach(e => e.classList.add('playing'));
      }
    }

    function draw() {
      let drawStep = lastDrawStep;
      const now = audioCtx.currentTime;
      while (notesInQueue.length && notesInQueue[0].time < now) {
        drawStep = notesInQueue[0].step;
        notesInQueue.shift();
      }
      if (drawStep !== lastDrawStep) {
        highlightColumn(drawStep);
        lastDrawStep = drawStep;
      }
      if (isPlaying) requestAnimationFrame(draw);
    }

    // ---- Transport controls ----
    const playBtn = document.getElementById('play-btn');
    const pauseBtn = document.getElementById('pause-btn');
    const clearBtn = document.getElementById('clear-btn');

    function showPlaying(playing) {
      playBtn.classList.toggle('hidden', playing);
      playBtn.classList.toggle('inline-flex', !playing);
      pauseBtn.classList.toggle('hidden', !playing);
      pauseBtn.classList.toggle('inline-flex', playing);
    }

    function startPlayback() {
      if (!audioCtx) initAudio();
      if (audioCtx.state === 'suspended') audioCtx.resume();
      isPlaying = true;
      currentStep = 0;
      lastDrawStep = -1;
      notesInQueue = [];
      nextNoteTime = audioCtx.currentTime + 0.06;
      scheduler();
      requestAnimationFrame(draw);
      showPlaying(true);
    }

    function stopPlayback() {
      isPlaying = false;
      if (timerID) clearTimeout(timerID);
      notesInQueue = [];
      lastDrawStep = -1;
      highlightColumn(-1);
      showPlaying(false);
    }

    playBtn.addEventListener('click', startPlayback);
    pauseBtn.addEventListener('click', stopPlayback);

    clearBtn.addEventListener('click', () => {
      INSTRUMENTS.forEach(i => pattern[i.id].fill(false));
      document.querySelectorAll('.step.active').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
    });

    // ---- Tempo + volume ----
    const tempoInput = document.getElementById('tempo');
    const tempoValue = document.getElementById('tempo-value');
    tempoInput.addEventListener('input', () => {
      tempo = parseInt(tempoInput.value, 10);
      tempoValue.textContent = tempo + ' BPM';
    });

    const volInput = document.getElementById('volume');
    const volValue = document.getElementById('volume-value');
    volInput.addEventListener('input', () => {
      masterVol = parseInt(volInput.value, 10) / 100;
      volValue.textContent = volInput.value;
      if (master) master.gain.setTargetAtTime(masterVol, audioCtx.currentTime, 0.01);
    });
  </script>
